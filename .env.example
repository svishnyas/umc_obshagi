# PostgreSQL (локально: docker compose up -d postgres → см. строку ниже)
DATABASE_URL="postgresql://umc:umc@localhost:5432/umc"

# Auth.js — для dev можно короткий строкой; в проде: openssl rand -base64 32
AUTH_SECRET="local-dev-secret-change-me"
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="http://localhost:3000"

# Загрузки: если НЕ заданы S3_* ниже — файлы пишутся в public/uploads (без MinIO).

# --- Опционально: S3 (если заданы все ключевые переменные — используется S3) ---
# S3_ENDPOINT="http://localhost:9000"
# S3_REGION="us-east-1"
# S3_BUCKET="umc"
# S3_ACCESS_KEY="minioadmin"
# S3_SECRET_KEY="minioadmin"
# S3_FORCE_PATH_STYLE="true"
# S3_PUBLIC_BASE_URL="http://localhost:9000/umc"

# --- Vercel / Neon: вставь строку подключения из консоли Neon (часто нужен ?sslmode=require) ---
# DATABASE_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
