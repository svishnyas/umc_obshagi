# --- Локально без Docker (рекомендуется для проверки) ---
DATABASE_URL="file:./prisma/dev.db"

# Auth.js — для dev можно короткий строкой; в проде: openssl rand -base64 32
AUTH_SECRET="local-dev-secret-change-me"
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="http://localhost:3000"

# Загрузки: если НЕ заданы S3_* ниже — файлы пишутся в public/uploads (без MinIO).

# --- Опционально: MinIO / S3 (если заданы все ключевые переменные — используется S3) ---
# DATABASE_URL="postgresql://umc:umc@localhost:5432/umc"
# S3_ENDPOINT="http://localhost:9000"
# S3_REGION="us-east-1"
# S3_BUCKET="umc"
# S3_ACCESS_KEY="minioadmin"
# S3_SECRET_KEY="minioadmin"
# S3_FORCE_PATH_STYLE="true"
# S3_PUBLIC_BASE_URL="http://localhost:9000/umc"
